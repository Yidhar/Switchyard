#!/usr/bin/env bash

# Check CARGO_TARGET_DIR environment variable
if [[ -n "$CARGO_TARGET_DIR" && "$CARGO_TARGET_DIR" == target-* ]]; then
    export CARGO_TARGET_DIR="target/$CARGO_TARGET_DIR"
fi

# Rebuild arguments
NEW_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --target-dir)
            if [[ "$2" == target-* ]]; then
                NEW_ARGS+=("--target-dir" "target/$2")
                shift 2
            else
                NEW_ARGS+=("$1" "$2")
                shift 2
            fi
            ;;
        *)
            NEW_ARGS+=("$1")
            shift
            ;;
    esac
done

# Find the real cargo.
# We search the PATH excluding the current directory to avoid recursion.
OLD_PATH="$PATH"
# Remove current directory and workspace root from PATH
CLEAN_PATH=$(echo "$PATH" | tr ':' '\n' | grep -v -E "^\.$|^\./$|$(pwd)" | tr '\n' ':')
PATH="$CLEAN_PATH"

real_cargo=$(which cargo 2>/dev/null)
if [ -z "$real_cargo" ]; then
    real_cargo="cargo"
fi

PATH="$OLD_PATH"
exec "$real_cargo" "${NEW_ARGS[@]}"

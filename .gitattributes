# Keep CI checks stable across Windows, macOS, and Linux checkouts.
* text=auto eol=lf

# Binary assets must never be line-ending normalized.
*.bmp binary
*.gif binary
*.icns binary
*.ico binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.png binary
*.webp binary
*.zip binary
*.gz binary
*.tgz binary
*.7z binary
*.exe binary
*.dll binary
